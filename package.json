{
	"private": true,
	"license": "UNLICENSED",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		]
	},
	"type": "module",
	"scripts": {
		"dev": "yarn workspace @rlanz/site dev",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:build": "docker build . -t site",
		"docker:run": "docker run --env-file ./apps/romainlanz.com/.env -e NODE_ENV=production -e HOST=0.0.0.0 -e DB_HOST=host.docker.internal -it -p 3333:3333 --add-host=host.docker.internal:host-gateway site",
		"lint": "oxlint",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"lint:fix": "oxlint --fix",
		"release": "node bin/release.mjs",
		"taze": "yarn dlx taze -r -I --maturity-period 3",
		"typecheck": "yarn workspaces foreach -p -A run typecheck"
	},
	"devDependencies": {
		"oxfmt": "^0.47.0",
		"oxlint": "^1.62.0"
	},
	"packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6"
}
